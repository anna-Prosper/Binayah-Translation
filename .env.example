# Translation API keys — get from DeepSeek / OpenRouter dashboards
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
# Optional: override the DeepSeek base URL (default https://api.deepseek.com/v1)
DEEPSEEK_BASE_URL=

# Admin password — superadmin login. Also the JWT signing key UNLESS JWT_SECRET is set.
ADMIN_SECRET=
# Dedicated JWT signing secret (recommended). If set, it — not ADMIN_SECRET —
# signs/verifies tokens, decoupling the signing key from the login password.
# Setting/rotating it invalidates all sessions (users just log in again).
JWT_SECRET=

# CORS allowlist (comma-separated origins allowed to call the API from a browser).
# Defaults to the admin URL. Non-browser callers (WordPress PHP, scripts) are unaffected.
ALLOWED_ORIGINS=

# WordPress connection — only needed for single-site local dev.
# For multi-site, register sites via the admin UI (stored in DATA_DIR/env-config.json).
WP_URL=
WP_API_KEY=

# Per-site WordPress API keys (bt_api_key) used by the plugin-deploy scripts and
# the GitHub "Deploy WordPress plugin" workflow (set as repo secrets of the same name).
WP_KEY_TEMP=
WP_KEY_STAGING=

# Data directory — where runtime JSON state is stored (default: api/ root).
# On Render this is the persistent disk mount path (/data).
DATA_DIR=

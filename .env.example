# Translation API keys — get from DeepSeek / OpenRouter dashboards
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=

# Admin password — used for superadmin login and JWT signing
ADMIN_SECRET=

# WordPress connection — only needed for single-site local dev
# For multi-site, use the admin UI to register sites (stored in DATA_DIR/env-config.json)
WP_URL=
WP_API_KEY=

# Data directory — where runtime JSON files are stored (default: api/ root)
# On Render this is set to /data (the persistent disk mount path)
DATA_DIR=

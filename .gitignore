# Dependencies - never commit these (700MB+)
node_modules/
admin/node_modules/
api/node_modules/

# Build output - regenerated by npm run build
admin/.next/
admin/out/

# Environment secrets - CRITICAL: never commit
api/.env
.env
.env.local
.env*.local

# Translation log - runtime data file (grows large)
api/translation-log.json

# Backup files - server-only backups
*.zip
BACKUP_*/

# System files
.DS_Store
Thumbs.db
npm-debug.log*

# Runtime data files - not for version control
api/translation-cache.json
api/usage-stats.json
api/users.json
api/page-config.json
api/language-config.json
api/global-config.json

# Environment config with API keys and site credentials - NEVER commit
api/env-config.json
api/sites.json
